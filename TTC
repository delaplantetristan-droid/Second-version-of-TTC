function findVerse(){
  const input=document.getElementById('prayerInput').value.toLowerCase();
  const response=document.getElementById('prayerResponse');
  if(!input.trim())return;
  let matched=null;
  for(const[pattern,verse]of Object.entries(prayerKeywords)){if(new RegExp(pattern,'i').test(input)){matched=verse;break;}}
  if(!matched)matched={text:"For I know the plans I have for you, declares the Lord, plans to prosper you and not to harm you, plans to give you hope and a future.",ref:"Jeremiah 29:11"};
  document.getElementById('prayerVerseText').innerHTML=`\u201C${matched.text}\u201D<br><br><span style="font-family:'Jost',sans-serif;font-style:normal;font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);">— ${matched.ref}</span>`;
  response.classList.add('show');
  response.scrollIntoView({behavior:'smooth',block:'nearest'});
}
