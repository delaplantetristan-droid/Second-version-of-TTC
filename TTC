let activeCategory=null,currentVerseIndex=0,activeAthleteCategory=null,currentAthleteVerseIndex=0;

const grid=document.getElementById('categoryGrid');
categories.forEach(cat=>{
  const card=document.createElement('div');
  card.className='category-card';card.id='cat-'+cat.id;
  card.innerHTML=`<span class="cat-icon">${cat.icon}</span><div class="cat-name">${cat.name}</div><div class="cat-desc">${cat.desc}</div><span class="cat-tag">${cat.tag}</span>`;
  card.addEventListener('click',()=>selectCategory(cat));grid.appendChild(card);
});

function selectCategory(cat){
  document.querySelectorAll('.category-card').forEach(c=>c.classList.remove('active'));
  document.getElementById('cat-'+cat.id).classList.add('active');
  activeCategory=cat;currentVerseIndex=0;showVerse();
  document.getElementById('verseDisplay').scrollIntoView({behavior:'smooth',block:'center'});
}
function showVerse(){
  if(!activeCategory)return;
  const verse=activeCategory.verses[currentVerseIndex];
  const display=document.getElementById('verseDisplay');
  display.classList.remove('visible');
  setTimeout(()=>{
    document.getElementById('verseLabel').textContent=activeCategory.icon+'  '+activeCategory.name+'  ·  Verse '+(currentVerseIndex+1)+' of '+activeCategory.verses.length;
    document.getElementById('verseText').textContent='\u201C'+verse.text+'\u201D';
    document.getElementById('verseRef').textContent='— '+verse.ref;
    const ref=document.getElementById('reflection');
    if(verse.reflection){document.getElementById('reflectionText').textContent=verse.reflection;ref.style.display='block';}else{ref.style.display='none';}
    display.classList.add('visible');
  },200);
}
function nextVerse(){if(!activeCategory)return;currentVerseIndex=(currentVerseIndex+1)%activeCategory.verses.length;showVerse();}
function prevVerse(){if(!activeCategory)return;currentVerseIndex=(currentVerseIndex-1+activeCategory.verses.length)%activeCategory.verses.length;showVerse();}

const athleteBtnContainer=document.getElementById('athleteSubBtns');
athleteCategories.forEach(cat=>{
  const btn=document.createElement('button');
  btn.className='athlete-sub-btn';btn.id='abtn-'+cat.id;btn.textContent=cat.label;
  btn.addEventListener('click',()=>selectAthleteCategory(cat));athleteBtnContainer.appendChild(btn);
});
function selectAthleteCategory(cat){
  document.querySelectorAll('.athlete-sub-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('abtn-'+cat.id).classList.add('active');
  activeAthleteCategory=cat;currentAthleteVerseIndex=0;showAthleteVerse();
}
function showAthleteVerse(){
  if(!activeAthleteCategory)return;
  const verse=activeAthleteCategory.verses[currentAthleteVerseIndex];
  const display=document.getElementById('athleteVerseDisplay');
  display.classList.remove('visible');
  setTimeout(()=>{
    document.getElementById('athleteLabel').textContent=activeAthleteCategory.label+'  ·  Verse '+(currentAthleteVerseIndex+1)+' of '+activeAthleteCategory.verses.length;
    document.getElementById('athleteVerseText').textContent='\u201C'+verse.text+'\u201D';
    document.getElementById('athleteVerseRef').textContent='— '+verse.ref;
    const ref=document.getElementById('athleteReflection');
    if(verse.reflection){document.getElementById('athleteReflectionText').textContent=verse.reflection;ref.style.display='block';}else{ref.style.display='none';}
    display.classList.add('visible');
  },200);
}
function nextAthleteVerse(){if(!activeAthleteCategory)return;currentAthleteVerseIndex=(currentAthleteVerseIndex+1)%activeAthleteCategory.verses.length;showAthleteVerse();}
function prevAthleteVerse(){if(!activeAthleteCategory)return;currentAthleteVerseIndex=(currentAthleteVerseIndex-1+activeAthleteCategory.verses.length)%activeAthleteCategory.verses.length;showAthleteVerse();}

